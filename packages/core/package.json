{
  "name": "@docsgen/core",
  "version": "0.0.0",
  "private": false,
  "description": "Docusaurus plugin for documentation generation based on your .ts files",
  "author": "Maciej Pyrc <maciekpyrc@gmail.com>",
  "homepage": "",
  "license": "Apache-2.0",
  "platform": "node",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "clean": "rimraf dist",
    "test": "vitest",
    "test:pipeline": "vitest run --reporter=verbose",
    "test:update-snapshot": "vitest run --update",
    "start": "vite build --watch",
    "build": "vite build",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "typecheck": "tsgo --noEmit",
    "release": "semantic-release --extends ./release.config.cjs -t 'docsgen-v${version}'"
  },
  "dependencies": {
    "listr2": "^8.2.5",
    "fs-extra": "^11.2.0",
    "js-beautify": "^1.15.1",
    "mdast-util-from-markdown": "^2.0.0",
    "mdast-util-mdx": "^3.0.0",
    "mdx-mermaid": "^2.0.0",
    "mermaid": ">=8.11.0",
    "micromark-extension-mdxjs": "2.0.0",
    "node-html-markdown": "^1.3.0",
    "node-html-parser": "^6.1.12",
    "pretty-format": "^29.7.0",
    "prism-react-renderer": "^2.3.1",
    "react": ">= 16.8.0",
    "react-dom": ">= 16.8.0",
    "react-live": "^4.1.5",
    "react-simple-code-editor": "^0.13.1",
    "remark-admonitions": "^1.2.1",
    "typedoc": "^0.25.7",
    "typedoc-plugin-markdown": "^3.17.1",
    "unist-util-is": "^6.0.0",
    "unist-util-visit": "5.0.0",
    "unist-util-visit-parents": "^6.0.1"
  },
  "devDependencies": {
    "@docusaurus/plugin-content-docs": ">= 2.0.0",
    "@docusaurus/types": ">= 2.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/js-beautify": "^1.14.3",
    "@types/pretty": "^2.0.3",
    "@types/react": "^18.0.21",
    "@types/react-dom": "^18.0.6",
    "outdent": "^0.8.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BetterTyped/docsgen.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/BetterTyped/docsgen/issues"
  },
  "keywords": [
    "docusaurus",
    "docgen",
    "typedoc",
    "api",
    "generation",
    "import",
    "docs",
    "documentation"
  ]
}
